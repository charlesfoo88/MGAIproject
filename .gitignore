*.bin
*.safetensors
*.onnx
*.pt
*.pth
*.h5

# Include bundled local embedding model required by the backend
!Backend/Models/
!Backend/Models/all-MiniLM-L6-v2/
!Backend/Models/all-MiniLM-L6-v2/**

# Keep certain directories but ignore contents
Backend/Outputs/*
!Backend/Outputs/.gitkeep
Backend/Source_Videos/*
!Backend/Source_Videos/.gitkeep
